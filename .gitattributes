# Default: normalize text files in Git.
* text=auto

# Python / docs / config: keep LF in repository.
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.spec text eol=lf

# Windows scripts / installer files: use CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.iss text eol=crlf

# Binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.db binary
*.db-shm binary
*.db-wal binary
*.zip binary
*.exe binary
*.msi binary
*.h5 binary
*.pyd binary
*.dll binary