# =========================================================
# FaceLens .gitignore
# Keep source code, docs, installer scripts, and specs.
# Ignore local runtime data, build outputs, secrets, and heavy generated files.
# =========================================================

# 1. Virtual environments
venv/
.venv/
env/
ENV/

# 2. Local configuration / secrets
.env
.env.*
!.env.example
config.ini
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
private_keys/
license_private_key*

# 3. Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 4. IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# 5. PyInstaller build artifacts
build/
dist/

# Keep PyInstaller spec files because they are release source.
!*.spec

# 6. Release output artifacts
release/
Output/

# Generated installers / binaries should not be committed.
*.exe
*.msi

# 7. Runtime app data
data/
logs/
backups/
temp_files/
.deepface/

# 8. Local databases / dumps / backups
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.dump
*.sql
*.bak

# 9. AI model weights / large downloaded files
*.h5
*.onnx
*.tflite
*.pt
*.pth
*.pb

# 10. Generated handoff / temporary files
handoff/
project_code_part_*.txt
project_structure.txt

# 11. Keep installer source files
# Do NOT ignore installer/ because it contains FaceLens_Installer.iss and installed_mode.txt.
!installer/
!installer/*.iss
!installer/*.txt
!installer/*.md

# 12. Keep assets source files
!assets/
!assets/*.png
!assets/*.ico
!assets/*.jpg
!assets/*.jpeg

# FaceLens runtime data
data/
logs/
backups/
temp_files/
.deepface/
